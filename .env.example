# FEDGE 2.O — Environment Variables
# Copy this file to .env and fill in your real keys
# NEVER commit .env to git

# ─── Equifax Developer API ───────────────────────────────────
# Sign up: https://developer.equifax.com
EQUIFAX_CLIENT_ID=your_equifax_client_id
EQUIFAX_CLIENT_SECRET=your_equifax_client_secret

# ─── Experian Developer API ──────────────────────────────────
# Sign up: https://developer.experian.com
EXPERIAN_CLIENT_ID=your_experian_client_id
EXPERIAN_CLIENT_SECRET=your_experian_client_secret

# ─── TransUnion API ──────────────────────────────────────────
# Contact: https://www.transunion.com/solution/developer-api
TRANSUNION_CLIENT_ID=your_transunion_client_id
TRANSUNION_CLIENT_SECRET=your_transunion_client_secret

# ─── Supabase (Backend) ───────────────────────────────────────
# Sign up: https://supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# ─── Analytics ───────────────────────────────────────────────
MIXPANEL_TOKEN=your_mixpanel_token
